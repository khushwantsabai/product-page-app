{% schema %}
{
  "name": "Pagecraft Template",
  "target": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "To customize the actual layout, product data, and gallery for this template, please use the visual editor inside the Pagecraft App."
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ]
}
{% endschema %}

<div style="padding-top: {{ block.settings.padding_top }}px; padding-bottom: {{ block.settings.padding_bottom }}px;">
  <div id="pagecraft-root">
    <div style="padding: 40px 20px; text-align: center; color: #6B7280; font-family: sans-serif; background: #F9FAFB; border: 1px dashed #D1D5DB; border-radius: 8px;">
      Loading Pagecraft Template...
    </div>
  </div>
</div>

<script>
  (function() {
    var isDesignMode = {{ request.design_mode | json }};
    var root = document.getElementById('pagecraft-root');
    
    fetch('/apps/product-page?designMode=' + (isDesignMode ? 'true' : 'false'))
      .then(function(res) { 
        if (!res.ok) throw new Error('Proxy response not ok');
        return res.json(); 
      })
      .then(function(data) {
        if (!data || !data.html) {
          if (root) root.innerHTML = '<div style="padding: 40px 20px; text-align: center; color: #6B7280; font-family: sans-serif; background: #F9FAFB; border: 1px dashed #D1D5DB; border-radius: 8px;">No published template found. Please publish a template in the app.</div>';
          return;
        }

        // Inject global CSS if not already injected
        if (data.css && !document.getElementById('ppb-styles')) {
          var style = document.createElement('div');
          style.id = 'ppb-styles';
          style.innerHTML = data.css;
          document.head.appendChild(style);
        }
        
        // Inject HTML
        if (root) root.innerHTML = data.html;
      })
      .catch(function(err) { 
        console.error("PPB Fetch Error:", err);
        if (root) root.innerHTML = '<div style="padding: 40px 20px; text-align: center; color: #EF4444; font-family: sans-serif; background: #FEF2F2; border: 1px dashed #FCA5A5; border-radius: 8px;">Failed to load template. Please ensure your App Proxy is configured to <b>apps/product-page</b> in the Partner Dashboard.</div>';
      });
  })();
</script>
