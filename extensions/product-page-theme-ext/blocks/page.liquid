{% schema %}
{
  "name": "Product Page Builder",
  "target": "section",
  "settings": []
}
{% endschema %}

<div id="product-page-container-{{ section.id }}" class="product-page-container">
  <p style="text-align: center; color: #666; font-family: sans-serif;">Loading Product Page Custom Layout...</p>
</div>

<script>
  (function() {
    var container = document.getElementById("product-page-container-{{ section.id }}");
    if (!container) return;
    
    var isDesignMode = {{ request.design_mode | json }};
    
    // Use the Shopify App Proxy route. Adjust the '/apps/product-page' prefix to match your app proxy configuration in the Partner Dashboard.
    fetch('/apps/product-page?designMode=' + (isDesignMode ? 'true' : 'false'))
      .then(function(response) { 
        if (!response.ok) {
          throw new Error('Network response was not ok');
        }
        return response.json(); 
      })
      .then(function(data) {
        if (data.html) {
            var section = container.closest('.shopify-section') || container.closest('section');
            if (section) {
                // Completely replace the default product section with our custom template!
                section.innerHTML = data.html;
            } else {
                container.innerHTML = data.html;
            }
        } else {
            container.style.display = "none";
        }
      })
      .catch(function(err) {
        console.error("Product Page Proxy Error:", err);
        container.innerHTML = "";
      });
  })();
</script>
