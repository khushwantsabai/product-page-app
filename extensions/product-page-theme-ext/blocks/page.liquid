{% schema %}
{
  "name": "Product Page Builder",
  "target": "section",
  "settings": []
}
{% endschema %}

<div id="product-page-container-{{ section.id }}" class="product-page-container">
  <p style="text-align: center; color: #666; font-family: sans-serif;">Loading Product Page Custom Layout...</p>
</div>

<script>
  (function() {
    var container = document.getElementById("product-page-container-{{ section.id }}");
    if (!container) return;
    
    // Use the Shopify App Proxy route. Adjust the '/apps/product-page' prefix to match your app proxy configuration in the Partner Dashboard.
    fetch('/apps/product-page')
      .then(function(response) { 
        if (!response.ok) {
          throw new Error('Network response was not ok');
        }
        return response.json(); 
      })
      .then(function(data) {
        if (data.html) {
            container.innerHTML = data.html;
        } else {
            container.innerHTML = "";
        }
      })
      .catch(function(err) {
        console.error("Product Page Proxy Error:", err);
        container.innerHTML = "";
      });
  })();
</script>
